# Storage
NCCN_ARCHIVE_DIR=/archive
NCCN_STATE_FILE=/archive/manifest.json
NCCN_INDEX_FILE=/archive/index.yaml

# Scheduling. Used only with `--daemon`.
NCCN_RUN_INTERVAL_HOURS=24

# Login mode. Use only with a valid NCCN account and within your license/terms.
NCCN_USERNAME=
NCCN_PASSWORD=

# Optional fallback if normal login is blocked by MFA/SSO/browser checks.
# Paste only your own NCCN session cookie string, and rotate it when expired.
NCCN_COOKIE=

# Optional comma-separated filters. Examples:
# NCCN_INCLUDE_SLUGS=breast-cancer,colon-cancer,gastric-cancer
# NCCN_EXCLUDE_SLUGS=older-adult-oncology
NCCN_INCLUDE_SLUGS=
NCCN_EXCLUDE_SLUGS=

# Defaults to the four NCCN professional guideline categories.
NCCN_CATEGORIES=1,2,3,4

# Optional: directly index selected detail pages instead of scanning categories.
# Example:
# NCCN_DETAIL_URLS=https://www.nccn.org/guidelines/nccn-guidelines/guidelines-detail?category=1&id=1434
NCCN_DETAIL_URLS=

# First-run safety. Set to 1-3 for testing, then clear it for full archive.
NCCN_LIMIT=

# Optional first-run indexing safety. Limits detail pages read per category.
NCCN_DETAIL_LIMIT=

# PDF variants to archive. Keep `primary` unless you explicitly need more.
# Options: primary,evidence_blocks,basic_framework,core_framework,enhanced_framework,patient,harmonized,all
NCCN_PDF_VARIANTS=primary

# Be gentle with NCCN services.
NCCN_REQUEST_DELAY_SECONDS=2
NCCN_MAX_CONCURRENCY=2
NCCN_MIN_PDF_BYTES=1024
